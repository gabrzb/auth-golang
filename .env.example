# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auth_db

# JWT
JWT_SECRET=your-secret-key-here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=168h

# Redis
REDIS_ADDR=localhost:6379

# Cookies / CORS
# COOKIE_SECURE marks the refresh-token cookie as Secure (HTTPS-only). Leave false for localhost.
COOKIE_SECURE=false
# Comma-separated list of allowed browser origins (CORS + origin-check on /auth/*).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1
